{
  "description": "RAG Web Browser Worker - Search Google and extract web page content for LLM processing. Enter a search query or a URL to scrape",
  "b": "query",
  "properties": [
    {
      "title": "Search query or URL",
      "name": "query",
      "type": "array",
      "editor": "requestList",
      "description": "Enter Google Search keywords or a URL to scrape",
      "default": [
        {
          "url": "web browser for RAG pipelines"
        }
      ],
      "required": true
    },
    {
      "title": "Maximum results",
      "name": "maxResults",
      "type": "integer",
      "editor": "number",
      "description": "Maximum number of search results",
      "default": 3
    },
    {
      "title": "Output format",
      "name": "outputFormat",
      "type": "string",
      "editor": "select",
      "description": "Output format for extracted content",
      "default": "markdown",
      "options": [
        { "label": "Markdown", "value": "markdown" },
        { "label": "Plain text", "value": "text" },
        { "label": "HTML", "value": "html" }
      ]
    },
    {
      "title": "Scraping tool",
      "name": "scrapingTool",
      "type": "string",
      "editor": "select",
      "description": "Choose scraping method",
      "default": "raw-http",
      "options": [
        { "label": "Raw HTTP (faster)", "value": "raw-http" },
        { "label": "Browser (Playwright)", "value": "browser-playwright" }
      ]
    },
    {
      "title": "Request timeout (seconds)",
      "name": "requestTimeoutSecs",
      "type": "integer",
      "editor": "number",
      "description": "Maximum time for the request",
      "default": 40
    }
  ]
}
